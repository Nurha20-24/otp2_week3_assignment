<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<VBox spacing="10" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.FuelCalculatorController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Language selection buttons -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="EN" onAction="#setEnglish"/>
        <Button text="FR" onAction="#setFrench"/>
        <Button text="JP" onAction="#setJapanese"/>
        <Button text="IR" onAction="#setPersian"/>
    </HBox>

    <Label fx:id="lblDistance"/>
    <TextField fx:id="txtDistance"/>

    <Label fx:id="lblConsumption"/>
    <TextField fx:id="txtConsumption"/>

    <Label fx:id="lblPrice"/>
    <TextField fx:id="txtPrice"/>

    <Button fx:id="btnCalculate" onAction="#calculate"/>
    <Label fx:id="lblResult"/>

    <Label text="Nur Hana" style="-fx-font-style: italic;"/>
</VBox>